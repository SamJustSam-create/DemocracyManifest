# ─── Required ─────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your application/client ID (found on the General Information page)
CLIENT_ID=your_application_client_id_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set this to register commands to a single guild instantly (good for testing).
# Leave empty to register commands globally (takes up to 1 hour to propagate).
GUILD_ID=your_guild_id_here
